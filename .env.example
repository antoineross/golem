# Required: Google API key (GOOGLE_API_KEY preferred, GEMINI_API_KEY also works)
GOOGLE_API_KEY=

# Required: Supacrawler API endpoint
# Local dev (outside docker): http://localhost:8083
# Inside docker-compose: http://scraper:8081
SUPACRAWL_API_URL=http://localhost:8083

# Optional: LLM models
DEFAULT_LLM_MODEL=gemini-3-flash-preview
FALLBACK_LLM_MODEL=gemini-3.1-flash-lite-preview

# Optional: log level (default: info)
GOLEM_LOG_LEVEL=info

# Optional: agent timeout in seconds (default: 120)
GOLEM_TIMEOUT_SECONDS=120

# Optional: Thinking mode (Gemini 3 models)
# ThinkingLevel: low, medium, high, minimal (default: medium)
GOLEM_THINKING_LEVEL=medium
# IncludeThoughts: return thought summaries in response (default: true)
GOLEM_INCLUDE_THOUGHTS=true
# ThinkingBudget: token budget for Gemini 2.5 models, 0=disabled (default: 0)
GOLEM_THINKING_BUDGET=0

# Optional: Backup API key from a different GCP project (rotated on 429 errors)
GOOGLE_API_KEY_BACKUP=

# Optional: Separate API key for the scraper service (reduces shared quota pressure)
# If set, scraper uses this key instead of GOOGLE_API_KEY
SCRAPER_GEMINI_API_KEY=

# Optional: Retry/backoff for 429 RESOURCE_EXHAUSTED errors
# MaxRetries: max retry attempts per model slot on rate limit (default: 5)
GOLEM_RETRY_MAX=5
# BaseDelay: initial backoff delay in ms (default: 2000)
GOLEM_RETRY_BASE_DELAY_MS=2000
# MaxDelay: maximum backoff delay cap in ms (default: 30000)
GOLEM_RETRY_MAX_DELAY_MS=30000

# Optional: OpenTelemetry tracing (ADK built-in)
# Write OTel spans to a JSON file (empty = disabled)
GOLEM_TRACE_FILE=
# Print OTel spans to stdout (default: false)
GOLEM_TRACE_CONSOLE=false
# Capture full message content in spans (default: false, to protect sensitive data)
# Set to true for rich observer traces with prompt/response text and thoughts
GOLEM_TRACE_CAPTURE_CONTENT=true
