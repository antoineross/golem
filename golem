#!/usr/bin/env bash
set -euo pipefail

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_NAME="${PROJECT_NAME:-golem}"
BASE_ENV_PATH="${REPO_ROOT}/.env"
LOCAL_ENV_PATH="${REPO_ROOT}/.env.local"
PID_FILE="${REPO_ROOT}/tmp/golem.pid"
LOG_DIR="${REPO_ROOT}/tmp/logs"
ENV_SOURCES=()
ENV_SOURCES_DISPLAY=""
ENV_LOADED=""

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err() { echo -e "${RED}[ERROR]${NC} $1"; }

ensure_tmp() {
  local dirs=("tmp" "tmp/versions" "tmp/reports" "tmp/screenshots" "tmp/tests" "tmp/logs")
  for d in "${dirs[@]}"; do
    mkdir -p "${REPO_ROOT}/${d}"
  done
}

trim_whitespace() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "${value}"
}

apply_env_file() {
  local env_path="$1"
  local line key raw

  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="${line%$'\r'}"
    line="$(trim_whitespace "${line}")"

    if [[ -z "${line}" || "${line:0:1}" == "#" ]]; then
      continue
    fi
    if [[ "${line}" == export* ]]; then
      line="$(trim_whitespace "${line#export}")"
    fi

    if [[ "${line}" =~ ^([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      raw="$(trim_whitespace "${BASH_REMATCH[2]}")"
      if [[ "${raw}" == \"*\" && "${raw}" == *\" ]]; then
        raw="${raw:1:${#raw}-2}"
      elif [[ "${raw}" == \'*\' && "${raw}" == *\' ]]; then
        raw="${raw:1:${#raw}-2}"
      else
        raw="$(trim_whitespace "${raw%%#*}")"
      fi
      printf -v "${key}" '%s' "${raw}"
      export "${key}"
    fi
  done < "${env_path}"
}

read_env_var_from_sources() {
  local key="$1"
  local value=""
  local env_path line raw

  for env_path in "${ENV_SOURCES[@]}"; do
    while IFS= read -r line || [[ -n "${line}" ]]; do
      line="${line%$'\r'}"
      line="$(trim_whitespace "${line}")"

      if [[ -z "${line}" || "${line:0:1}" == "#" ]]; then
        continue
      fi
      if [[ "${line}" == export* ]]; then
        line="$(trim_whitespace "${line#export}")"
      fi

      if [[ "${line}" =~ ^${key}[[:space:]]*=(.*)$ ]]; then
        raw="$(trim_whitespace "${BASH_REMATCH[1]}")"
        if [[ "${raw}" == \"*\" && "${raw}" == *\" ]]; then
          raw="${raw:1:${#raw}-2}"
        elif [[ "${raw}" == \'*\' && "${raw}" == *\' ]]; then
          raw="${raw:1:${#raw}-2}"
        else
          raw="$(trim_whitespace "${raw%%#*}")"
        fi
        value="${raw}"
      fi
    done < "${env_path}"
  done

  printf '%s' "${value}"
}

check_env() {
  ENV_SOURCES=()
  ENV_SOURCES_DISPLAY=""
  ENV_LOADED=""

  if [[ -f "${BASE_ENV_PATH}" ]]; then
    ENV_SOURCES+=("${BASE_ENV_PATH}")
    ENV_SOURCES_DISPLAY=".env"
  fi
  if [[ -f "${LOCAL_ENV_PATH}" ]]; then
    ENV_SOURCES+=("${LOCAL_ENV_PATH}")
    if [[ -n "${ENV_SOURCES_DISPLAY}" ]]; then
      ENV_SOURCES_DISPLAY="${ENV_SOURCES_DISPLAY} + .env.local"
    else
      ENV_SOURCES_DISPLAY=".env.local"
    fi
  fi

  if [[ ${#ENV_SOURCES[@]} -eq 0 && -f "${REPO_ROOT}/.env.example" ]]; then
    log_warn "no .env.local/.env found; creating .env.local from .env.example"
    cp "${REPO_ROOT}/.env.example" "${REPO_ROOT}/.env.local"
    log_warn "fill in .env.local values, then retry"
    exit 1
  elif [[ ${#ENV_SOURCES[@]} -eq 0 ]]; then
    log_warn "no env files found; some commands may not work without configuration"
    ENV_SOURCES_DISPLAY="(none)"
    return
  fi

  if [[ "${ENV_SOURCES_DISPLAY}" == ".env + .env.local" ]]; then
    log_info "loading .env (base) with .env.local overrides"
  else
    log_info "loading ${ENV_SOURCES_DISPLAY}"
  fi
}

load_env() {
  if [[ -n "${ENV_LOADED}" ]]; then
    return
  fi

  local env_path
  for env_path in "${ENV_SOURCES[@]}"; do
    apply_env_file "${env_path}"
  done

  ENV_LOADED="1"
}

check_go() {
  if ! command -v go >/dev/null 2>&1; then
    log_err "go is required but not installed"
    exit 1
  fi
}

usage() {
  cat <<'EOF'
golem - agent workflow CLI

Usage: ./golem <command> [options]

Commands:
  start           Start the golem agent
  stop            Stop the golem agent
  restart         Restart the golem agent
  status          Show agent process status
  env list        Show env configuration status
  build           Build the Go binary
  lint            Run linters
  test            Run tests
  e2e [name]      Run E2E test harness (thinking, agent, level0)
  help            Show this help
EOF
}

is_golem_alive() {
  local pid="$1"
  kill -0 "${pid}" 2>/dev/null
}

kill_tree() {
  local pid="$1"
  local child
  for child in $(pgrep -P "${pid}" 2>/dev/null); do
    kill_tree "${child}"
  done
  kill -TERM "${pid}" 2>/dev/null || true
}

cmd_start() {
  check_go
  check_env
  load_env
  ensure_tmp

  if [[ -f "${PID_FILE}" ]]; then
    local existing_pid
    existing_pid=$(<"${PID_FILE}")
    if is_golem_alive "${existing_pid}"; then
      log_warn "golem is already running (pid ${existing_pid})"
      return
    fi
    log_info "cleaning stale pid file (pid ${existing_pid})"
    rm -f "${PID_FILE}"
  fi

  if [[ ! -f "${REPO_ROOT}/apps/golem/go.mod" ]]; then
    log_err "apps/golem/go.mod not found; initialize the module first"
    exit 1
  fi

  local log_file="${LOG_DIR}/golem-$(date +%Y%m%d-%H%M%S).log"
  local pid_file="${PID_FILE}"
  log_info "starting golem agent"

  (
    cd "${REPO_ROOT}/apps/golem"
    exec go run ./cmd/golem/main.go
  ) > "${log_file}" 2>&1 &
  local pid=$!

  sleep 0.3
  if ! is_golem_alive "${pid}"; then
    log_err "golem failed to start -- check ${log_file}"
    rm -f "${pid_file}"
    return 1
  fi

  echo "${pid}" > "${pid_file}"
  log_ok "golem started (pid ${pid}, log ${log_file})"

  (
    wait "${pid}" 2>/dev/null
    rm -f "${pid_file}"
  ) &
  disown
}

cmd_stop() {
  if [[ ! -f "${PID_FILE}" ]]; then
    log_warn "golem is not running (no pid file)"
    return
  fi

  local pid
  pid=$(<"${PID_FILE}")
  if is_golem_alive "${pid}"; then
    kill_tree "${pid}"
    local i=0
    while is_golem_alive "${pid}" && [[ $i -lt 10 ]]; do
      sleep 0.2
      ((i++))
    done
    if is_golem_alive "${pid}"; then
      kill -KILL "${pid}" 2>/dev/null || true
    fi
    log_ok "golem stopped (pid ${pid})"
  else
    log_warn "golem process ${pid} already exited; cleaning up"
  fi
  rm -f "${PID_FILE}"
}

cmd_status() {
  if [[ ! -f "${PID_FILE}" ]]; then
    echo "golem: not running"
    return
  fi

  local pid
  pid=$(<"${PID_FILE}")
  if is_golem_alive "${pid}"; then
    local cmd_line
    cmd_line="$(ps -p "${pid}" -o args= 2>/dev/null || echo "unknown")"
    echo "golem: running (pid ${pid})"
    echo "  cmd: ${cmd_line}"
  else
    echo "golem: not running (stale pid file)"
    rm -f "${PID_FILE}"
  fi
}

cmd_env_list() {
  check_env
  load_env

  local required_vars=(
    "GOOGLE_API_KEY"
    "SUPACRAWL_API_URL"
  )
  local optional_vars=(
    "DEFAULT_LLM_MODEL"
    "FALLBACK_LLM_MODEL"
    "GOLEM_LOG_LEVEL"
    "GOLEM_TIMEOUT_SECONDS"
    "GOLEM_THINKING_LEVEL"
    "GOLEM_INCLUDE_THOUGHTS"
    "GOLEM_THINKING_BUDGET"
    "GOLEM_TRACE_FILE"
    "GOLEM_TRACE_CONSOLE"
    "GOLEM_TRACE_CAPTURE_CONTENT"
  )

  echo "Environment sources: ${ENV_SOURCES_DISPLAY}"
  echo ""
  echo "Required:"
  for var_name in "${required_vars[@]}"; do
    if [[ -n "$(trim_whitespace "$(read_env_var_from_sources "${var_name}")")" ]]; then
      echo "  ${var_name}=SET"
    else
      echo "  ${var_name}=MISSING"
    fi
  done
  echo ""
  echo "Optional:"
  for var_name in "${optional_vars[@]}"; do
    if [[ -n "${!var_name:-}" ]]; then
      echo "  ${var_name}=SET"
    else
      echo "  ${var_name}=DEFAULT"
    fi
  done
}

cmd_build() {
  check_go
  if [[ ! -f "${REPO_ROOT}/apps/golem/go.mod" ]]; then
    log_err "apps/golem/go.mod not found; initialize the module first"
    exit 1
  fi
  log_info "building golem"
  (cd "${REPO_ROOT}/apps/golem" && go build ./...)
  log_ok "build complete"
}

cmd_lint() {
  if [[ -f "${REPO_ROOT}/apps/golem/go.mod" ]]; then
    log_info "running go vet"
    (cd "${REPO_ROOT}/apps/golem" && go vet ./...)
    log_ok "go vet passed"
  else
    log_warn "apps/golem/go.mod not present; skipping lint"
  fi
}

cmd_test() {
  if [[ -f "${REPO_ROOT}/apps/golem/go.mod" ]]; then
    log_info "running go test"
    (cd "${REPO_ROOT}/apps/golem" && go test ./...)
    log_ok "tests passed"
  else
    log_warn "apps/golem/go.mod not present; skipping tests"
  fi
}

cmd_e2e() {
  check_go
  check_env
  load_env
  ensure_tmp

  local harness="${1:-thinking}"
  local out_dir="${REPO_ROOT}/tmp/tests/${harness}"
  mkdir -p "${out_dir}"

  case "${harness}" in
    thinking)
      log_info "running thinking mode E2E harness"
      (cd "${REPO_ROOT}/apps/golem" && OUTPUT_DIR="${out_dir}" go run ./cmd/thinking-test/main.go)
      log_ok "thinking E2E complete -- output: ${out_dir}/"
      ls -la "${out_dir}/"
      ;;
    agent)
      local log_file="${out_dir}/agent_e2e_run.log"
      local trace_file="${out_dir}/agent_otel_spans.json"
      local prompt="${2:-}"
      if [[ -z "${prompt}" ]]; then
        prompt="Echo 'hello' to verify tool calling works, then list the available payload categories."
      fi
      log_info "running full agent E2E"
      local e2e_rc=0
      (cd "${REPO_ROOT}/apps/golem" && \
        GOLEM_TRACE_FILE="${trace_file}" \
        GOLEM_TRACE_CAPTURE_CONTENT=true \
        go run ./cmd/golem/main.go "${prompt}") > "${log_file}" 2>&1 || e2e_rc=$?
      if [[ "${e2e_rc}" -ne 0 ]]; then
        log_err "agent E2E failed (exit code ${e2e_rc}) -- check ${log_file}"
        ls -la "${out_dir}/"
        exit "${e2e_rc}"
      fi
      log_ok "agent E2E complete -- output: ${out_dir}/"
      ls -la "${out_dir}/"
      ;;
    level0)
      local log_file="${out_dir}/level0_e2e.log"
      local trace_file="${out_dir}/level0_otel_spans.json"
      local prompt="Echo 'hello' to verify tool calling works, then list the available payload categories."
      log_info "running level 0 E2E (echo + payload, no scraper required)"
      local e2e_rc=0
      (cd "${REPO_ROOT}/apps/golem" && \
        GOLEM_TRACE_FILE="${trace_file}" \
        GOLEM_TRACE_CAPTURE_CONTENT=true \
        go run ./cmd/golem/main.go "${prompt}") > "${log_file}" 2>&1 || e2e_rc=$?
      if [[ "${e2e_rc}" -ne 0 ]]; then
        log_err "level 0 E2E failed (exit code ${e2e_rc}) -- check ${log_file}"
        ls -la "${out_dir}/"
        exit "${e2e_rc}"
      fi
      log_ok "level 0 E2E complete -- output: ${out_dir}/"
      ls -la "${out_dir}/"
      ;;
    *)
      log_err "unknown E2E harness: ${harness}"
      echo "Available: thinking, agent, level0"
      exit 1
      ;;
  esac
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "${cmd}" in
    start) cmd_start "$@" ;;
    stop) cmd_stop "$@" ;;
    restart) cmd_stop && cmd_start ;;
    status) cmd_status ;;
    build) cmd_build ;;
    env)
      local sub="${1:-}"
      if [[ "${sub}" == "list" ]]; then
        cmd_env_list
      else
        log_err "usage: ./golem env list"
        exit 1
      fi
      ;;
    lint) cmd_lint ;;
    test) cmd_test ;;
    e2e) cmd_e2e "$@" ;;
    help|-h|--help) usage ;;
    *)
      log_err "unknown command: ${cmd}"
      usage
      exit 1
      ;;
  esac
}

main "$@"
