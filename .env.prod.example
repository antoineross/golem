# ==============================================================================
# Golem Production Environment Variables
# ==============================================================================
# Copy this to .env.prod on the GCE VM and fill in values.
# DO NOT commit the filled-in file.

# --- Application Secrets ---
# [DOCKER SECRET + GITHUB SECRET] Gemini API key
GOOGLE_API_KEY=

# --- LLM Configuration ---
# [ENV VAR] Model selection (no secrets, safe as env vars)
DEFAULT_LLM_MODEL=gemini-3-flash-preview
GOLEM_LOG_LEVEL=info
GOLEM_TIMEOUT_SECONDS=120
GOLEM_THINKING_LEVEL=medium

# ==============================================================================
# GitHub Secrets (set in GitHub repo > Settings > Secrets > Actions)
# ==============================================================================
# These are NOT in the .env file -- they live only in GitHub Secrets.
#
# --- GCP Configuration ---
# GCP_PROJECT_ID=manila-research
# GCP_LOCATION=us-central1
# GCP_REPOSITORY=golem
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/992658392877/locations/global/workloadIdentityPools/<POOL_ID>/providers/<PROVIDER_ID>
# GCP_SERVICE_ACCOUNT_EMAIL=golem-sa@manila-research.iam.gserviceaccount.com
#
# --- Deployment ---
# DEPLOY_HOST=34.16.87.152
# DEPLOY_USER=deploy_golem
# DEPLOY_SSH_PRIVATE_KEY=<contents of ~/.ssh/deploy_golem>
#
# --- Application ---
# GOOGLE_API_KEY=<gemini api key>

# ==============================================================================
# Docker Secrets (created on the VM via `printf "value" | docker secret create name -`)
# ==============================================================================
# For Docker Swarm deployments (future):
#   printf "<key>" | docker secret create google_api_key -
#
# For docker-compose deployments (current):
#   Secrets are passed as env vars in docker-compose.prod.yml.
#   The GOOGLE_API_KEY above is the only true secret needed.

# ==============================================================================
# GCP Resource Setup Commands (run once)
# ==============================================================================
# Create Artifact Registry:
#   gcloud artifacts repositories create golem \
#     --repository-format=docker \
#     --location=us-central1 \
#     --project=manila-research
#
# Create service account for GitHub Actions (push):
#   gcloud iam service-accounts create golem-sa --project=manila-research
#   gcloud projects add-iam-policy-binding manila-research \
#     --member="serviceAccount:golem-sa@manila-research.iam.gserviceaccount.com" \
#     --role="roles/artifactregistry.writer"
#
# Create Workload Identity Federation pool:
#   gcloud iam workload-identity-pools create golem-github-pool \
#     --project=manila-research --location=global
#   gcloud iam workload-identity-pools providers create-oidc github-provider \
#     --project=manila-research --location=global \
#     --workload-identity-pool=golem-github-pool \
#     --issuer-uri=https://token.actions.githubusercontent.com \
#     --attribute-mapping="google.subject=assertion.sub,attribute.repository=assertion.repository" \
#     --attribute-condition="assertion.repository=='antoineross/golem'"
#   gcloud iam service-accounts add-iam-policy-binding \
#     golem-sa@manila-research.iam.gserviceaccount.com \
#     --project=manila-research \
#     --role="roles/iam.workloadIdentityUser" \
#     --member="principalSet://iam.googleapis.com/projects/992658392877/locations/global/workloadIdentityPools/golem-github-pool/attribute.repository/antoineross/golem"
#
# Generate deploy SSH key (on local machine):
#   ssh-keygen -t ed25519 -f ~/.ssh/deploy_golem -C "github_actions_golem"
#   # Add the public key to the deploy user on the VM
#
# Verify setup:
#   gcloud artifacts repositories list --project=manila-research --location=us-central1
#   gcloud iam service-accounts list --project=manila-research
