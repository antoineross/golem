# ==============================================================================
# Golem Production Environment Variables
# ==============================================================================
# Copy this to .env.prod on the GCE VM and fill in values.
# DO NOT commit the filled-in file.

# --- Application Secrets ---
# [GITHUB SECRET + VM ENV] Gemini API key
GOOGLE_API_KEY=

# --- LLM Configuration ---
# [ENV VAR] Model selection (no secrets, safe as env vars)
DEFAULT_LLM_MODEL=gemini-3-flash-preview
GOLEM_LOG_LEVEL=info
GOLEM_TIMEOUT_SECONDS=120
GOLEM_THINKING_LEVEL=medium

# --- Traefik / SSL ---
# [GITHUB SECRET] Domain for HTTPS (Traefik will get a Let's Encrypt cert)
DOMAIN=
# [GITHUB SECRET] Email for Let's Encrypt certificate notifications
ACME_EMAIL=

# ==============================================================================
# GitHub Secrets (set in GitHub repo > Settings > Secrets > Actions)
# ==============================================================================
# These are NOT in the .env file -- they live only in GitHub Secrets.
#
# --- GCP Configuration ---
# GCP_PROJECT_ID=<YOUR_PROJECT_ID>
# GCP_LOCATION=<YOUR_REGION>          (e.g. us-central1)
# GCP_REPOSITORY=<YOUR_AR_REPO>       (e.g. golem)
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/<PROJECT_NUMBER>/locations/global/workloadIdentityPools/<POOL_ID>/providers/<PROVIDER_ID>
# GCP_SERVICE_ACCOUNT_EMAIL=<SA_NAME>@<PROJECT_ID>.iam.gserviceaccount.com
#
# --- Deployment ---
# DEPLOY_HOST=<VM_EXTERNAL_IP>
# DEPLOY_USER=<DEPLOY_USERNAME>
# DEPLOY_SSH_PRIVATE_KEY=<contents of deploy private key>
#
# --- Application ---
# GOOGLE_API_KEY=<gemini api key>

# ==============================================================================
# Docker Secrets (created on the VM via `printf "value" | docker secret create name -`)
# ==============================================================================
# For Docker Swarm deployments (future):
#   printf "<key>" | docker secret create google_api_key -
#
# For docker-compose deployments (current):
#   Secrets are passed as env vars in docker-compose.prod.yml.
#   The GOOGLE_API_KEY above is the only true secret needed.

# ==============================================================================
# GCP Resource Setup Commands (run once)
# ==============================================================================
# Replace all <PLACEHOLDERS> with your actual values before running.
#
# Create Artifact Registry:
#   gcloud artifacts repositories create <YOUR_AR_REPO> \
#     --repository-format=docker \
#     --location=<YOUR_REGION> \
#     --project=<YOUR_PROJECT_ID>
#
# Create service account for GitHub Actions (push):
#   gcloud iam service-accounts create <SA_NAME> --project=<YOUR_PROJECT_ID>
#   gcloud projects add-iam-policy-binding <YOUR_PROJECT_ID> \
#     --member="serviceAccount:<SA_NAME>@<YOUR_PROJECT_ID>.iam.gserviceaccount.com" \
#     --role="roles/artifactregistry.writer"
#
# Create Workload Identity Federation pool:
#   gcloud iam workload-identity-pools create <POOL_NAME> \
#     --project=<YOUR_PROJECT_ID> --location=global
#   gcloud iam workload-identity-pools providers create-oidc <PROVIDER_NAME> \
#     --project=<YOUR_PROJECT_ID> --location=global \
#     --workload-identity-pool=<POOL_NAME> \
#     --issuer-uri=https://token.actions.githubusercontent.com \
#     --attribute-mapping="google.subject=assertion.sub,attribute.repository=assertion.repository" \
#     --attribute-condition="assertion.repository=='<GITHUB_ORG>/<GITHUB_REPO>'"
#   gcloud iam service-accounts add-iam-policy-binding \
#     <SA_NAME>@<YOUR_PROJECT_ID>.iam.gserviceaccount.com \
#     --project=<YOUR_PROJECT_ID> \
#     --role="roles/iam.workloadIdentityUser" \
#     --member="principalSet://iam.googleapis.com/projects/<PROJECT_NUMBER>/locations/global/workloadIdentityPools/<POOL_NAME>/attribute.repository/<GITHUB_ORG>/<GITHUB_REPO>"
#
# Generate deploy SSH key (on local machine):
#   ssh-keygen -t ed25519 -f ~/.ssh/deploy_<PROJECT> -C "github_actions_deploy"
#   # Add the public key to the deploy user on the VM
#
# Verify setup:
#   gcloud artifacts repositories list --project=<YOUR_PROJECT_ID> --location=<YOUR_REGION>
#   gcloud iam service-accounts list --project=<YOUR_PROJECT_ID>
